# terraform/terraform.tfvars.example
# 실제 값은 terraform.tfvars에 작성 (git에 커밋하지 않음)

aws_region    = "ap-northeast-2"
environment   = "dev"
project_name  = "rum-pipeline"

# Agent UI 인프라
vpc_id                 = "vpc-xxxxxxxxxxxxxxxxx"
public_subnet_ids      = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-xxxxxxxxxxxxxxxxx"]
agentcore_endpoint_arn = "arn:aws:bedrock-agentcore:ap-northeast-2:<account-id>:runtime/<agent-id>/runtime-endpoint/<endpoint-name>"

# CORS 허용 도메인 (프로덕션에서는 특정 도메인으로 제한)
allowed_origins = ["https://your-domain.com"]
