[Unit]
Description=RUM AgentCore HTTP Proxy (route.ts → AgentCore Runtime SSE)
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/opt/rum-agent-ui/agentcore
EnvironmentFile=/opt/rum-agent-ui/.env
ExecStart=/usr/bin/python3 proxy.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=rum-agent

[Install]
WantedBy=multi-user.target
