# AWS RUM Pipeline 환경 변수
# 이 파일을 .env로 복사하고 실제 값으로 교체하세요.
# cp .env.example .env

# AWS 설정
AWS_REGION=ap-northeast-2
AWS_PROFILE=default

# Terraform
TF_VAR_project_name=rum-pipeline
TF_VAR_environment=dev

# API Gateway (배포 후 설정)
# RUM_API_ENDPOINT=https://<api-id>.execute-api.ap-northeast-2.amazonaws.com

# Grafana (선택)
# GRAFANA_WORKSPACE_ENDPOINT=https://<workspace-id>.grafana-workspace.ap-northeast-2.amazonaws.com
# GRAFANA_API_KEY=glsa_xxxxxxxxxxxx

# AgentCore (선택)
# BEDROCK_AGENT_ID=
# BEDROCK_AGENT_ALIAS_ID=

# Cognito SSO (선택)
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=

# Claude Code 알림 웹훅 (선택)
# CLAUDE_NOTIFY_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
